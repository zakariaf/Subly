# Template for .kamal/secrets — copy to .kamal/secrets (gitignored) and fill in.
# NEVER commit real values. Kamal sources this file as a shell script, so $(...)
# command substitution and shell-env references both work.
#
# Simplest approach: export these in your shell or CI before `kamal deploy`, and
# the lines below forward them into Kamal:
#
#   export KAMAL_REGISTRY_PASSWORD=...   # Docker Hub access token (read/write)
#   export TELEGRAM_BOT_TOKEN=...        # from @BotFather
#   export OPENAI_API_KEY=...            # only if translating via OpenAI / Whisper API

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
TELEGRAM_BOT_TOKEN=$TELEGRAM_BOT_TOKEN
OPENAI_API_KEY=$OPENAI_API_KEY

# --- Alternative: 1Password CLI (no secrets ever touch disk) -----------------
# Install `op`, run `op account add` once, then replace the three lines above:
#
# SECRETS=$(kamal secrets fetch --adapter 1password --account YOUR_1P_ACCOUNT_ID --from Vault/Subly \
#   KAMAL_REGISTRY_PASSWORD TELEGRAM_BOT_TOKEN OPENAI_API_KEY)
# KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
# TELEGRAM_BOT_TOKEN=$(kamal secrets extract TELEGRAM_BOT_TOKEN ${SECRETS})
# OPENAI_API_KEY=$(kamal secrets extract OPENAI_API_KEY ${SECRETS})
