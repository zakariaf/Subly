# Template for .kamal/secrets — copy to .kamal/secrets (gitignored) and fill in.
# NEVER commit real values. Kamal sources this file as a shell script, so $(...)
# command substitution and shell-env references both work.

SECRETS=$(kamal secrets fetch --adapter 1password --account DW4Z52QDBNBK3MMVVC5QKOA3QM --from Keys/Subly common/KAMAL_REGISTRY_PASSWORD production/LLM_API_KEY production/OPENAI_API_KEY production/TELEGRAM_BOT_TOKEN production/TELEGRAM_API_ID production/TELEGRAM_API_HASH)

# GitHub Container Registry PAT — used by Kamal to pull/push the image.
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})

# App env.secret values.
LLM_API_KEY=$(kamal secrets extract LLM_API_KEY ${SECRETS})
OPENAI_API_KEY=$(kamal secrets extract OPENAI_API_KEY ${SECRETS})

TELEGRAM_BOT_TOKEN=$(kamal secrets extract TELEGRAM_BOT_TOKEN ${SECRETS})
TELEGRAM_API_ID=$(kamal secrets extract TELEGRAM_API_ID ${SECRETS})
TELEGRAM_API_HASH=$(kamal secrets extract TELEGRAM_API_HASH ${SECRETS})
