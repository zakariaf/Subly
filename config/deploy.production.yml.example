# Real deployment values for the `production` destination.
#
#   cp config/deploy.production.yml.example config/deploy.production.yml
#   # edit in your host (and any overrides), then:
#   kamal deploy -d production
#
# config/deploy.production.yml is GITIGNORED. Values here are merged OVER
# config/deploy.yml (arrays like `hosts` are replaced, not appended).

servers:
  bot:
    hosts:
      - 203.0.113.10            # <-- your server's IP or hostname

# If you keep the telegram-bot-api accessory, set its host to the same server
# (the base file's &host anchor only resolves within config/deploy.yml):
# accessories:
#   telegram-bot-api:
#     host: 203.0.113.10

# Override anything else from config/deploy.yml as needed, e.g.:
#
# ssh:
#   user: deployer
#
# env:
#   clear:
#     LLM_BASE_URL: https://api.deepseek.com   # translate with DeepSeek instead of OpenAI
#     TRANSLATION_MODEL: deepseek-chat
#     TRANSCRIBE_BACKEND: openai               # offload transcription to OpenAI Whisper
#
# (LLM_API_KEY / OPENAI_API_KEY are secrets — set them in .kamal/secrets, not here.)
