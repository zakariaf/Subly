# --- Telegram ---
# Get a token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Max size (MB) the bot will accept. Standard Bot API getFile cap is 20;
# raise this only if you run a local Bot API server.
MAX_FILE_MB=20

# --- Transcription ---
# "local"  -> faster-whisper on this machine (free, no API key)
# "openai" -> OpenAI Whisper API (needs OPENAI_API_KEY)
TRANSCRIBE_BACKEND=local
# local backend only: tiny | base | small | medium | large-v3
WHISPER_MODEL=small
# auto | cpu | cuda
WHISPER_DEVICE=auto
# int8 (cpu) | float16 (gpu) | default
WHISPER_COMPUTE_TYPE=int8

# --- Translation (any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
TRANSLATION_MODEL=gpt-4o-mini
# Segments translated per LLM request.
TRANSLATION_BATCH_SIZE=40
# Per-request timeout (seconds) and automatic retries for transient errors.
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2

# --- Defaults ---
DEFAULT_TARGET_LANGUAGE=English
