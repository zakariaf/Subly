# --- Telegram ---
# Get a token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Max size (MB) the bot accepts (download) and sends. Cloud Bot API caps these at
# 20 / 50; raise them only when using a local Bot API server (below).
MAX_FILE_MB=20
SEND_LIMIT_MB=50

# --- Local Bot API server (optional — for files > 20 MB) ---
# Run the telegram-bot-api server (Docker Compose `--profile local-api`, or the
# Kamal accessory) and point the bot at it to lift the 20/50 MB caps. Needs an
# api_id + api_hash from https://my.telegram.org. Leave blank to use the cloud API.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Where the bot reaches the server (compose: telegram-bot-api; Kamal: subly-telegram-bot-api):
# TELEGRAM_API_BASE=http://telegram-bot-api:8081
# TELEGRAM_LOCAL_MODE=1
# Then raise the limits, e.g. MAX_FILE_MB=2000 and SEND_LIMIT_MB=2000.

# --- Transcription ---
# "local"      -> faster-whisper on this machine (CPU, free, no API key)
# "openai"     -> OpenAI Whisper API (needs OPENAI_API_KEY below)
# "assemblyai" -> AssemblyAI STT (needs ASSEMBLYAI_API_KEY; falls back to local on failure)
TRANSCRIBE_BACKEND=local
# local backend only: tiny | base | small | medium | large-v3
WHISPER_MODEL=small
# auto | cpu | cuda   (no GPU assumed; "auto" resolves to cpu)
WHISPER_DEVICE=auto
# int8 (cpu) | float16 (gpu) | default
WHISPER_COMPUTE_TYPE=int8
# Only used when TRANSCRIBE_BACKEND=openai. Most LLM providers (e.g. DeepSeek)
# have no transcription endpoint, so this stays pointed at OpenAI.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Only used when TRANSCRIBE_BACKEND=assemblyai. Falls back to local Whisper on any
# failure. For EU data residency, set ASSEMBLYAI_BASE_URL=https://api.eu.assemblyai.com.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com
# Ordered fallback list of speech models (comma-separated). Universal-2 is the default
# because Universal-3 Pro doesn't cover some languages (e.g. Arabic, Persian).
ASSEMBLYAI_SPEECH_MODELS=universal-2

# --- Translation (any OpenAI-compatible LLM) ---
# Separate key/URL/model from transcription, so the LLM can be a different provider:
#   OpenAI:   LLM_BASE_URL=https://api.openai.com/v1   TRANSLATION_MODEL=gpt-4o-mini
#   DeepSeek: LLM_BASE_URL=https://api.deepseek.com    TRANSLATION_MODEL=deepseek-chat
#   Gemini:   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/   TRANSLATION_MODEL=gemini-2.5-flash
#             (Gemini is OpenAI-compatible; gemini-2.5-flash has a free tier ~1,500 req/day)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
TRANSLATION_MODEL=gpt-4o-mini
# Segments translated per LLM request.
TRANSLATION_BATCH_SIZE=40

# --- Shared HTTP (both API clients) ---
# Per-request timeout (seconds) and automatic retries for transient errors.
REQUEST_TIMEOUT=60
MAX_RETRIES=2

# --- Concurrency ---
# How many media jobs run in parallel. The I/O-bound transcribe/translate stages
# overlap across jobs; the CPU-bound video burn is bounded separately below.
MAX_CONCURRENT_JOBS=4
# Simultaneous video burns (re-encode). x264 already uses every core, so 1 avoids
# CPU thrashing under parallel jobs; raise only on a large multi-core host.
MAX_CONCURRENT_BURNS=1

# --- Subtitles ---
# Longest a single subtitle cue may span (seconds). AssemblyAI returns whole
# sentences (often 20-30s); its word timestamps are repacked into cues no longer
# than this. Lower = shorter, snappier lines; higher = fewer, longer ones.
MAX_SUBTITLE_DURATION=6

# --- Defaults ---
DEFAULT_TARGET_LANGUAGE=English
